# Frontend env (Vite picks up VITE_-prefixed vars at build time)
# Where the Stripe Checkout backend lives. After you deploy to Vercel,
# replace this with your actual Vercel app URL, e.g.:
#   VITE_STRIPE_BACKEND_URL=https://nzmp-website.vercel.app
#
# Leave blank ("") if the React app is hosted on the SAME origin as the
# function (e.g. when both are served by Vercel itself).
VITE_STRIPE_BACKEND_URL=

# Backend env vars (set on the host that runs the function — never commit)
# STRIPE_SECRET_KEY=sk_test_xxxxx          # Stripe — set in Vercel (api/createStripeCheckout.js)
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxx  # Brevo — set in Ezsite .env (email/sendBulkEmail Deno function)
# ALLOWED_ORIGIN=https://nzmeltingpot.com  # optional — restrict CORS for Vercel functions
